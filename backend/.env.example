TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15557654321

SWEEP_ALERTS_ENABLED=true
SWEEP_SMS_ENABLED=true
SWEEP_POLL_SECONDS=60
SWEEP_INTERVAL=5m
SWEEP_TICKERS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD
SWEEP_TIMEZONE=America/New_York
SWEEP_NY_OPEN_START=08:00
SWEEP_NY_OPEN_END=10:00

# Backtest data source: yahoo (default) or dukascopy for deeper history
BACKTEST_DATA_SOURCE=dukascopy
# Optional Dukascopy settings
DUKASCOPY_BASE_URL=https://datafeed.dukascopy.com/datafeed
DUKASCOPY_CACHE_DIR=backend/data/dukascopy
DUKASCOPY_TIMEOUT_SECONDS=12
DUKASCOPY_LOG_PROGRESS=true
DUKASCOPY_LOG_EVERY_HOURS=24
DUKASCOPY_SKIP_WEEKENDS=true
DUKASCOPY_MAX_WORKERS=6
DUKASCOPY_BATCH_HOURS=24
DUKASCOPY_RETRY_MAX=2
DUKASCOPY_AUTO_RESUME=true
DUKASCOPY_RETRY_PASSES=1
